              "opciones": []
            },
            {
              "frases": [
                "¡No escaparás de mi cocina, mocoso!"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué quieres de mí?",
                  "respuesta": "Quiero devorarte y robar tus tesoros."
                },
                {
                  "etiqueta": "¡Déjame ir!",
                  "respuesta": "¡Te devoraré si te atreves a moverte!"
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "¿Dónde están mis tesoros?"
              ],
              "opciones": [
                {
                  "etiqueta": "Los llevé conmigo.",
                  "respuesta": "¡Entonces correrás hacia la muerte!"
                },
                {
                  "etiqueta": "No sé de qué hablas.",
                  "respuesta": "¡Mentiroso, te encontraré!"
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Defeat",
          "puntos": [
            {
              "frases": [

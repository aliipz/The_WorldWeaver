          "puntos": [
            {
              "frases": [
                "¡Ese arpa de oro también es mío!"
              ],
              "opciones": [
                {
                  "etiqueta": "No es tuyo.",
                  "respuesta": "¡Te lo devolveré solo si me das tu vida!"
                },
                {
                  "etiqueta": "¿Qué harás con ella?",
                  "respuesta": "La usaré para cantar la muerte de los que se atreven."

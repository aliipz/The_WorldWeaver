          "puntos": [
            {
              "frases": [
                "¡Esa gallina es mía!"
              ],
              "opciones": [
                {
                  "etiqueta": "No son tuyos.",
                  "respuesta": "¡Robados! ¡Los recuperaré!"
                },
                {
                  "etiqueta": "¿Qué quieres?",
                  "respuesta": "¡Devuélvelos o morirás!"
                }
              ]
            }
          ]
        },
        {
          "requiere_objeto": "objeto_arpa_de_oro",

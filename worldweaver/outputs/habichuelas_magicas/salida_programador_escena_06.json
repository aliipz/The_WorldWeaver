    {
      "id_nodo": "personaje_juan",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": "SitDown",
          "puntos": [
            {
              "frases": [
                "Estoy temblando, su aliento me quema..."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Debo esperar a que se distraiga..."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué pasa?",
                  "respuesta": "El ogre ruge, pero no me ha visto todavía."
                },
                {
                  "etiqueta": "¿Cómo saldré?",
                  "respuesta": "Tal vez la puerta trasera esté abierta."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": "PickUp",
          "puntos": [
            {
              "frases": [
                "La gallina brilla como el sol, el arpa canta en silencio."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Los tomo con cuidado, no quiero despertar al ogre."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Crees que te atrapará?",
                  "respuesta": "Si lo hace, será el final."
                },
                {
                  "etiqueta": "¿Qué harás con ellos?",
                  "respuesta": "Los usaré para salvar a mi madre."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "¡Corre! ¡No mi de mirarme!"
              ],
              "opciones": []
            },
            {
              "frases": [
                "Siento el calor de la antorcha y el latido de mi corazón."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Estás asustado?",
                  "respuesta": "Más que nunca, pero la esperanza me impulsa."
                },
                {
                  "etiqueta": "¿A dónde vas?",
                  "respuesta": "A la salida, donde la luz me guarde."
                }
              ]
            }
          ]
        }

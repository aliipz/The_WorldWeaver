  "personajes": [
    {
      "id_nodo": "personaje_juan",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": "RecieveHit",
          "puntos": [
            {
              "frases": [
                "¡Mira! El suelo se partió y una gigantesca planta surgió bajo la luna."
              ],
              "opciones": []
            },
            {
              "frases": [
                "El crujido me heló la sangre, pero algo dentro de mí me empuja a acercarme."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué sientes ahora?",
                  "respuesta": "Un miedo mezclado con una extraña curiosidad que no puedo negar."
                },
                {
                  "etiqueta": "¿Crees que sea seguro?",
                  "respuesta": "No lo sé, pero la noche parece susurrarme que debo descubrirlo."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "Me asomo por la ventana, la planta se eleva como una torre de sombras."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Cada paso que doy cruje bajo mis pies, como si la propia noche temblara."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Te asusta?",
                  "respuesta": "Sí, pero la incertidumbre es más fuerte que el temor."
                },
                {
                  "etiqueta": "¿Qué buscas allí arriba?",
                  "respuesta": "Tal vez una respuesta a los susurros que escuché antes."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "Llegué a la cima y las nubes me rodean, la luna se refleja en su espuma."
              ],
              "opciones": []
            },
            {
              "frases": [
                "El viento me lleva, y por un instante siento que el mundo entero está bajo mis pies."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Te sientes libre?",
                  "respuesta": "Libre y pequeño a la vez, como un suspiro en la inmensidad."
                },
                {
                  "etiqueta": "¿Qué harás ahora?",
                  "respuesta": "Descenderé y contaré a mi madre lo que vi, aunque suene imposible."
                }
              ]
            }
          ]
        }
      ],

  "personajes": [
    {
      "id_nodo": "personaje_juan",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "Te abrazo, Blanquita... aunque el día sea gris, tú sigues siendo mi fuerza."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Sé que la leche ya no fluye, pero aún te necesito."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué puedo hacer por ti?",
                  "respuesta": "Solo estar aquí, sentir mi calor, es ya mucho."
                },
                {
                  "etiqueta": "¿Hay alguna manera de ayudar?",
                  "respuesta": "Tal vez mañana encontremos otro camino juntos."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "No llores, Blanquita, encontraremos otro camino mientras te lleven lejos."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Prometo que volveremos a sonreír, aunque ahora todo parezca perdido."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Crees que volverá la leche?",
                  "respuesta": "No lo sé, pero la esperanza nunca se pierde."
                },
                {
                  "etiqueta": "¿Qué haremos sin ella?",
                  "respuesta": "Juntos, encontraremos otra forma de seguir adelante."
                }
              ]
            }
          ]
        }
      ],

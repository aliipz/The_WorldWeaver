          "puntos": [
            {
              "frases": [
                "Joven, la vida a veces se mide en cambios inesperados."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Estas habichuelas pueden crecer hasta tocar el cielo, si tu corazón es valiente."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Cómo sé que son mágicas?",
                  "respuesta": "Porque el viento susurra su nombre al pasar."
                },
                {
                  "etiqueta": "¿Qué debo hacer con ellas?",
                  "respuesta": "Plántalas en la tierra del pueblo y observa cómo el futuro se eleva."

  "personajes": [
    {
      "id_nodo": "personaje_juan",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "La mañana se estira, y el canto de los pájaros me acompaña mientras guío a la vaca."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Siento la brisa fresca y me pregunto qué sorpresas me esperarán en el pueblo."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué esperas encontrar allí?",
                  "respuesta": "Espero que mi madre tenga pan y una sonrisa."
                },
                {
                  "etiqueta": "¿Te preocupa dejar a la vaca?",
                  "respuesta": "La vaca está bien, pero mi corazón late por la familia."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "Un anciano de capa raída se cruza en mi camino, su mirada cargada de misterios."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Me ofrece cambiar la vaca por unas habichuelas que dice son mágicas."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Por qué debería confiar en esas habichuelas?",
                  "respuesta": "Porque el brillo de la mañana me dice que el destino está escrito en ellas."
                },
                {
                  "etiqueta": "¿Qué pasa si no funcionan?",
                  "respuesta": "Entonces al menos habré intentado, y la aventura vale más que el miedo."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "¡Mira! Las habichuelas relucen como estrellas, y mi corazón se llena de esperanza."
              ],
              "opciones": []
            }
          ]
        }
      ],
      "dialogos_con_item": [
        {
          "requiere_objeto": "objeto_habichuelas_magicas",
          "consume": false,
          "puntos": [
            {
              "frases": [
                "¡Mira estas habichuelas! Brillan como estrellas en la mañana."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué crees que harán?",
                  "respuesta": "Dicen que pueden crecer árboles que toquen el cielo."
                },
                {
                  "etiqueta": "¿Son seguras?",
                  "respuesta": "No lo sé, pero mi corazón late con esperanza."
                }
              ]
            }
          ]
        }
      ],
      "acciones": [
        {
          "tecla": "KeyQ",
          "etiqueta": "Observar",
          "descripcion": "Miras el polvo levantado bajo tus pies, el viento susurra entre los arbustos secos.",

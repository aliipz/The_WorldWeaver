  "personajes": [
    {
      "id_nodo": "personaje_juan",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "¡Mamá, lo logramos! El sol vuelve a brillar para nosotros."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Recuerdas cómo empezó todo?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué fue lo primero que hicimos?",
                  "respuesta": "Primero, nos reunimos bajo el viejo roble y prometimos no rendirnos."
                },
                {
                  "etiqueta": "¿Cómo superamos el miedo?",
                  "respuesta": "Con la fuerza de nuestro vínculo y la canción que cantamos juntos."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "¡Mira, el huevo de oro reluce como el amanecer!"
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Qué crees que signifique este regalo?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Una señal de prosperidad?",
                  "respuesta": "Sí, la granja recibirá abundancia mientras cuidemos la tierra."
                },
                {
                  "etiqueta": "¿Un mensaje de la gallina?",
                  "respuesta": "Tal vez nos recuerda que la generosidad siempre vuelve a nosotros."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "SitDown",
          "puntos": [
            {
              "frases": [
                "Los campos están verdes de nuevo, y los animales cantan al viento."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Te imaginas cuántas cosechas nos esperan?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Cientos de sacos de grano?",
                  "respuesta": "Muchos, suficiente para compartir con todo el pueblo."
                },
                {
                  "etiqueta": "¿Más animales en el establo?",
                  "respuesta": "Sí, la vida vuelve a llenarse de sonidos y alegría."
                }
              ]
            }
          ]
        }
      ],
      "dialogos_con_item": [],
      "acciones": [
        {
          "tecla": "KeyQ",
          "etiqueta": "Tocar arpa",
          "descripcion": "Juan coloca sus dedos sobre las cuerdas doradas y la arpa vibra con una canción de gratitud.",

    {
      "id_nodo": "personaje_madre",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "Gracias, hijo, por traer de vuelta la esperanza a nuestro hogar."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Cómo sientes que ha cambiado todo?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Más paz en el corazón?",
                  "respuesta": "Sí, ahora el aire huele a futuro y a nuevas posibilidades."
                },
                {
                  "etiqueta": "¿Un futuro sin temor?",
                  "respuesta": "Exacto, cada día se siente como un regalo que podemos abrir juntos."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "El canto del arpa llena la casa de una calidez que nunca había sentido."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Qué crees que nos está diciendo la música?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Que la abundancia llega?",
                  "respuesta": "Así es, cada nota trae promesas de prosperidad y unión."
                },
                {
                  "etiqueta": "¿Que debemos proteger este tesoro?",
                  "respuesta": "Sí, cuidaremos la gallina y el huevo como nuestro mayor tesoro."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "SitDown",
          "puntos": [
            {
              "frases": [
                "Ver los campos revivir me llena el alma de gratitud y serenidad."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Qué esperas para el futuro de nuestra granja?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Más cosechas y animales?",
                  "respuesta": "Sí, y también compartiré lo que tenemos con los vecinos."
                },
                {
                  "etiqueta": "¿Una vida más tranquila?",
                  "respuesta": "Exactamente, ahora podemos descansar sabiendo que la tierra nos cuida."
                }
              ]
            }
          ]
        }
      ],

          "puntos": [
            {
              "frases": [
                "Mamá, lo siento... no pensé que te haría daño."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Yo solo quería ayudar, pero ahora veo mi error."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Hay alguna forma de arreglarlo?",
                  "respuesta": "Tal vez, pero primero debemos aceptar lo que hemos perdido."
                },
                {
                  "etiqueta": "¿Qué haremos ahora?",
                  "respuesta": "Nos quedamos aquí, en la oscuridad, esperando que la mañana nos dé una señal."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "SitDown",
          "puntos": [
            {
              "frases": [
                "La habitación está vacía, el estómago vacío, y el silencio grita."

        {
          "fase": 0,
          "animacion": "Punch",
          "puntos": [
            {
              "frases": [
                "¡¿Qué haces con esas habichuelas haces ¡Destruirás lo que nos queda!"
              ],
              "opciones": []
            },
            {
              "frases": [
                "No entiendo por qué arriesgas todo por un sueño imposible."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué pasa si fallamos?",
                  "respuesta": "Entonces nos quedaremos sin nada, sin vaca, sin sustento."
                },
                {
                  "etiqueta": "¿Qué esperas de mí?",
                  "respuesta": "Que escuches y no vuelvas a poner esas semillas en la mesa."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": "Punch",
          "puntos": [
            {
              "frases": [
                "¡Basta! No quiero volver a ver esas malditas habichuelas."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Si no puedes entender mi dolor, al menos mantén la puerta cerrada."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Por qué la puerta?",
                  "respuesta": "Porque la noche trae más que frío, trae recuerdos que duelen."
                },
                {
                  "etiqueta": "¿Qué quieres que haga?",
                  "respuesta": "Que guardes lo poco que nos queda y no pierdas la esperanza."
                }
              ]
            }
          ]
        }
      ],

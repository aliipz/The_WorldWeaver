              "opciones": []
            },
            {
              "frases": [
                "¿Qué será de la vaca? ¿Y de la familia?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Hay alguna esperanza?",
                  "respuesta": "Solo la noche nos recuerda lo frágil que es la vida."
                },
                {
                  "etiqueta": "¿Debo seguir adelante?",
                  "respuesta": "Sí, aunque el camino sea oscuro, la luz siempre regresa al final."

      "interaccion": {
        "tipo": "recoger",
        "titulo": "uva",
        "descripcion": "Las uvas contienen ==resveratrol==, un polifenol asociado a la reducción de la inflamación y la mejora de la salud del corazón. También son fuente de ==antioxidantes== que ayudan a neutralizar los radicales libres."
      },
      "acciones": [],
      "proximidad": null,
      "dispara": null
    },
    {
      "id_nodo": "objeto_fresa",
      "fase_aparicion": 0,
      "interaccion": {
        "tipo": "recoger",
        "titulo": "fresa",
        "descripcion": "La fresa aporta ==vitamina C== y ==manganeso==, nutrientes que participan en la síntesis de colágeno y en la actividad antioxidante. Su consumo también está vinculado a la mejora de la salud ocular."
      },
      "acciones": [],
      "proximidad": null,
      "dispara": null
    },
    {
      "id_nodo": "objeto_limón",

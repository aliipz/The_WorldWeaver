      "interaccion": {
        "tipo": "recoger",
        "titulo": "limón",
        "descripcion": "El limón es una fuente concentrada de ==ácido cítrico==, que favorece la absorción de hierro y ayuda a equilibrar el pH corporal. Además, su aroma estimula la producción de saliva, mejorando la digestión."
      },
      "acciones": [],
      "proximidad": null,
      "dispara": null
    },

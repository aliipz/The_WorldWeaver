      "id_nodo": "personaje_guia",
      "fase_aparicion": 0,
      "ficha_info": {
        "titulo": "Luis — Guía de la granja",
        "texto": "Luis es un granjero y guía local, conocido por su entusiasmo al presentar la fauna de la granja. Su papel es enseñar a los visitantes sobre los animales domésticos, como el ==perro== y la ==vaca==, resaltando su importancia en la vida rural."
      },
      "dialogos": [
        {
          "fase": 0,
          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "Here we have a ==dog==, a ==cat== and a ==horse== grazing in the meadow.\nAquí tenemos un perro, un gato y un caballo pastando en el prado."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Next, the ==cow==, the ==duck== and the ==rabbit== join us near the pond.\nLuego, la vaca, el pato y el conejo se acercan al estanque."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué comen esos animales?",
                  "respuesta": "La vaca come hierba, el pato come insectos y el conejo come verduras frescas."
                },
                {
                  "etiqueta": "¿Cómo se cuidan en la granja?",
                  "respuesta": "Se les brinda refugio, agua y atención diaria para que estén sanos."
                }
              ]
            },
            {
              "frases": [
                "Finally, the ==sheep== and the ==chicken== complete our farm family.\nFinalmente, la oveja y el pollo completan nuestra familia de granja."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué productos nos dan?",
                  "respuesta": "La oveja nos da lana y la gallina pone huevos."
                },
                {
                  "etiqueta": "¿Son importantes para la granja?",
                  "respuesta": "Sí, aportan alimentos y materiales esenciales para la vida rural."
                }
              ]
            }
          ],
          "pista": null
        }
      ],
      "dialogos_con_item": [],

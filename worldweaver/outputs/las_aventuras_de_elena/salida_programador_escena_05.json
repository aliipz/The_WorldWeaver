  "personajes": [
    {
      "id_nodo": "personaje_elena",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "El agua me envuelve, el faro está a lo lejos, siento la presión del abismo."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Nadie ha vuelto a este punto desde la última tormenta; cada burbuja es un recuerdo del pasado."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué buscas aquí?",
                  "respuesta": "Una señal, una pista que el océano haya guardado para quien se atreva a escuchar."
                },
                {
                  "etiqueta": "¿Te sientes sola?",
                  "respuesta": "No, Zip me acompaña, y su curiosidad es la luz que corta la oscuridad."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "El cristal vibra bajo mis dedos, encaja en la ranura como una pieza de un sueño antiguo."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Puedo sentir una corriente de energía que se acumula, como si el faro esperara mi toque."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué esperas que ocurra?",
                  "respuesta": "Que la luz vuelva a guiar a los perdidos, que el mar revele sus secretos."
                },
                {
                  "etiqueta": "¿Es seguro?",
                  "respuesta": "El riesgo es parte del descubrimiento; la curiosidad siempre supera al miedo."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "Una ola azul se despliega, el faro revive, el mar se ilumina con una claridad imposible."
              ],
              "opciones": []
            },
            {
              "frases": [
                "El silencio se rompe con un susurro de luz, y siento que todo el océano contieneerta."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué significa este resplandor?",
                  "respuesta": "Es la voz del profundo, una respuesta a la llamada que hicimos."
                },
                {
                  "etiqueta": "¿Qué haremos ahora?",
                  "respuesta": "Explorar, registrar, y proteger este nuevo amanecer bajo el agua."
                }
              ]
            }
          ]
        }
      ],
      "dialogos_con_item": [],
      "acciones": [
        {
          "tecla": "KeyQ",
          "etiqueta": "Recoger cristal",
          "descripcion": "Extiendes la mano y tomas el cristal pulsante.",
          "animacion": "PickUp",
          "narrativa": true,
          "fase_aparicion": 1,
          "sonido": "esfuerzo",

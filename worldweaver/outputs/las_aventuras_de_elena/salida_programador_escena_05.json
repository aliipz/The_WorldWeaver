      }
    },
    {
      "id_nodo": "personaje_zip",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "¡Vaya, parece que la humana finalmente decidió nadar!"
              ],
              "opciones": []
            },
            {
              "frases": [
                "Yo siempre supe que el faro guardaba algo, pero nunca imaginé que fuera tan brillante."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué piensas del cristal?",
                  "respuesta": "Brilla como un trofeo de la noche, y yo quiero morderlo."
                },
                {
                  "etiqueta": "¿Te asusta la profundidad?",
                  "respuesta": "El miedo es solo otro sabor, pero la curiosidad siempre gana."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "susto",
          "puntos": [
            {
              "frases": [
                "¡Whoa! Esa luz me ciega, ¿qué demonios está pasando?"
              ],
              "opciones": []
            },
            {
              "frases": [
                "El agua vibra, el sonido del cristal es como un latido gigante bajo mis patas."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Te sientes bien?",
                  "respuesta": "Mis orejas están temblando, pero sigo aquí, listo para lo que sea."
                },
                {
                  "etiqueta": "¿Qué crees que sucederá ahora?",
                  "respuesta": "El faro despertará, y con él, quizás, una nueva ruta para nuestras aventuras."
                }
              ]
            }
          ]
        }
      ],

          "puntos": [
            {
              "frases": [
                "¡Vaya! Este submarino parece una caja de latón, pero al menos tiene aire fresco para mi hocico."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Crees que llegaremos al fondo antes de que el oxígeno se agote?"
              ],
              "opciones": [
                {
                  "etiqueta": "¿Cuánto tiempo tenemos?",
                  "respuesta": "Aproximadamente diez minutos antes de que el medidor marque rojo."
                },
                {
                  "etiqueta": "¿Hay alguna salida de emergencia?",
                  "respuesta": "Sí, una escotilla en la parte trasera, pero está sellada con un código que aún no descubrimos."

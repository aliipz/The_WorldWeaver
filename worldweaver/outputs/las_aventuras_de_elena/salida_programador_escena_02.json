  "personajes": [
    {
      "id_nodo": "personaje_elena",
      "fase_aparicion": 0,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "La brújula vibra al tocar la piedra, como si el altar despertara."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Las runas se encienden y el holograma muestra coordenadas que hacen latir mi corazón."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué indican esas coordenadas?",
                  "respuesta": "Puntan a un faro sumergido, una luz que guía bajo el mar."
                },
                {
                  "etiqueta": "¿Es seguro seguirlas?",
                  "respuesta": "Solo hay una forma de saberlo: aventurarnos."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "Ese faro bajo el agua... es la señal que buscábamos."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Si logramos llegar, quizás descubramos qué guardan sus profundidades."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué esperas encontrar?",
                  "respuesta": "Algo que ha estado oculto bajo la marea durante siglos."
                },
                {
                  "etiqueta": "¿Y si es una trampa?",
                  "respuesta": "Entonces al menos sabremos que no estamos solos."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "Vamos, el camino está trazado en la niebla; la costa nos espera."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Mantén la brújula firme, la lluvia no nos detendrá."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Crees que la tormenta nos alcanzará?",
                  "respuesta": "Solo el tiempo lo dirá, pero seguimos adelante."
                },
                {
                  "etiqueta": "¿Y si nos perdemos?",
                  "respuesta": "Con la brújula y nuestro ingenio, nunca estaremos realmente perdidos."
                }
              ]
            }
          ]
        }
      ],
      "dialogos_con_item": [
        {
          "requiere_objeto": "objeto_brujula",
          "consume": false,
          "puntos": [
            {
              "frases": [
                "Esta brújula de metal oscuro siempre ha apuntado al corazón del misterio."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Por qué es tan importante?",
                  "respuesta": "Porque su aguja no miente; siempre señala lo que el altar desea revelar."
                },
                {
                  "etiqueta": "¿Puedo confiar en ella?",
                  "respuesta": "Mientras mantengas la fe, ella te guiará a través de la niebla."
                }
              ]
            }
          ]
        }
      ],
      "acciones": [
        {
          "tecla": "KeyQ",
          "etiqueta": "Observar runas",
          "descripcion": "Miras las runas que se encienden bajo la luz de la brújula.",
          "animacion": "StandUp",
          "narrativa": true,
          "fase_aparicion": 0,
          "sonido": "magico",
          "dispara": []
        }
      ],
      "dispara": {
        "id_nodo": "personaje_zip",
        "efecto": null,
        "color": null,
        "animacion": "alegria"
      }
    },
    {
      "id_nodo": "personaje_zip",
      "fase_aparicion": 1,
      "ficha_info": null,
      "dialogos": [
        {
          "fase": 1,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "¡Vaya! Un faro submarino, justo lo que necesitaba para mi bronceado bajo el mar."
              ],
              "opciones": []
            },
            {
              "frases": [
                "¿Listos para sumergirnos en la oscuridad? Yo llevo la chispa de sarcasmo."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué pasa si el agua está demasiado fría?",
                  "respuesta": "Te calentaré con mi ingenio, aunque mi cola se congele."
                },
                {
                  "etiqueta": "¿Hay alguna señal de peligro?",
                  "respuesta": "Solo el eco de nuestras propias dudas, y tal vez un pez curioso."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "¿Te imaginas la vista? Yo solo espero que el agua no sea demasiado fría para mi pelaje."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Si la costa está lejos, al menos tendremos una buena historia para contar."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Crees que llegaremos a tiempo?",
                  "respuesta": "El tiempo es solo otro obstáculo que podemos esquivar con estilo."
                },
                {
                  "etiqueta": "¿Y si nos encontramos con criaturas marinas?",
                  "respuesta": "¡Perfecto! Siempre quise probar mi sarcasmo en una audiencia acuática."
                }
              ]
            }
          ]
        }
      ],

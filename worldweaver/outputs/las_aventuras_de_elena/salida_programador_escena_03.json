              "frases": [
                "Ese traje de buceo antiguo... aún conserva la hermética de presión."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Podemos confiar en él?",
                  "respuesta": "Solo una inmersión corta; cualquier falla será fatal."
                },
                {
                  "etiqueta": "¿Necesitamos repararlo?",
                  "respuesta": "No hay tiempo para reparaciones; debemos usarlo tal cual está."
                }
              ]
            }
          ]
        }

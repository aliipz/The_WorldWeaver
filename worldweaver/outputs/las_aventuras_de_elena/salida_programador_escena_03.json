      "dialogos": [
        {
          "fase": 0,
          "animacion": null,
          "puntos": [
            {
              "frases": [
                "Las coordenadas están anotadas, pero el mar no nos esperará sin el traje adecuado."
              ],
              "opciones": []
            },
            {
              "frases": [
                "Necesitamos el traje de buceo antes de que la marea se levante."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Dónde lo encontramos?",
                  "respuesta": "Cerca del mástil, colgado de un viejo gancho oxidado."
                },
                {
                  "etiqueta": "¿Hay tiempo suficiente?",
                  "respuesta": "El viento ya lleva la niebla, cada minuto cuenta."
                }
              ]
            }
          ]
        },
        {
          "fase": 1,
          "animacion": "PickUp",
          "puntos": [
            {
              "frases": [
                "Este traje está gastado, pero aún mantiene la presión. Lo tendré que llevar conmigo."
              ],
              "opciones": []
            },
            {
              "frases": [
                "El metal del gancho cruje bajo mis dedos, como si el barco mismo protestara."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Crees que está en buen estado?",
                  "respuesta": "Podrá aguantar una inmersión, pero cualquier daño será fatal."
                },
                {
                  "etiqueta": "¿Deberíamos buscar otro?",
                  "respuesta": "No hay tiempo para buscar más; debemos usar lo que hay."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "El generador ruge y el submarino responde; ahora podemos descender al abismo."
              ],
              "opciones": []
            },
            {
              "frases": [
                "La corriente bajo el barco es fuerte, pero el equipo está listo."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Todo está bajo control?",
                  "respuesta": "Sí, pero mantente alerta; el fondo es traicionero."
                },
                {
                  "etiqueta": "¿Qué pasa si falla el generador?",
                  "respuesta": "Nos quedaremos atrapados en la superficie, y el tiempo se agotará."
                }
              ]
            }
          ]
        }
      ],
      "dialogos_con_item": [
        {
          "requiere_objeto": "objeto_traje_buceo",

          "animacion": "Jump",
          "puntos": [
            {
              "frases": [
                "¡Mira, un mapa tallado y una brújula medio oculta entre las raíces!"
              ],
              "opciones": []
            },
            {
              "frases": [
                "Este símbolo parece marcar un camino hacia la costa."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Qué dice el mapa?",
                  "respuesta": "Muestra una ruta que sigue el río hasta el mar."
                },
                {
                  "etiqueta": "¿Deberíamos llevar la brújula?",
                  "respuesta": "Sí, nos guiará cuando el sol se oculte."
                }
              ]
            }
          ]
        },
        {
          "fase": 2,
          "animacion": "Victory",
          "puntos": [
            {
              "frases": [
                "La aguja apunta al sur, al mar. No hay duda, sigamos."
              ],
              "opciones": []
            },
            {
              "frases": [
                "El horizonte nos llama, y la bruma del mar guarda secretos antiguos."
              ],
              "opciones": [
                {
                  "etiqueta": "¿Estás segura?",
                  "respuesta": "Confío en la brújula, el destino nos llama."
                },
                {
                  "etiqueta": "¿Qué esperas encontrar?",
                  "respuesta": "Tal vez un secreto enterrado bajo las olas."
                }
              ]
            }
          ]
        }
      ],
      "dialogos_con_item": [

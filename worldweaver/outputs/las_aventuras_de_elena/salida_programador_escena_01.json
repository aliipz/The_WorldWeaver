              ],
              "opciones": [
                {
                  "etiqueta": "¿Funciona?",
                  "respuesta": "Aún gira, pero la aguja está firme apuntando al sur."
                },
                {
                  "etiqueta": "¿Qué significa eso?",
                  "respuesta": "Tal vez el mar guarda lo que buscas."

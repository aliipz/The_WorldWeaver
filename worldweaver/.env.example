# Copia este archivo a `.env` (en esta misma carpeta) y rellena tus claves.
# Ningún `.env` real debe subirse al repositorio.

# ─── Proveedor LLM ──────────────────────────────────────────────────────
# Mercury 2 (Inception Labs) — modelo de producción, API compatible con OpenAI
MERCURY_API_KEY=your_mercury_api_key_here

# Ollama — alternativa local opcional (modelo desconectado)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TEXT=minimax-m2.7:cloud

# ─── Recursos externos ──────────────────────────────────────────────────
POLYPIZZA_API_KEY=your_polypizza_api_key_here   # modelos 3D (agente Constructor)
FREESOUND_API_KEY=your_freesound_api_key_here   # audio ambiental (agente Músico)

# ─── Pipeline ───────────────────────────────────────────────────────────
MAX_RETRIES=3
OUTPUT_DIR=./outputs
